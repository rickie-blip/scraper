{
  "version": 2,
  "installCommand": "npm install --prefix Frontend && npm install --prefix Backend",
  "buildCommand": "npm run build --prefix Frontend",
  "outputDirectory": "Frontend/dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/search-:path*", "destination": "/api/index.js" },
    { "source": "/scrape-:path*", "destination": "/api/index.js" },
    { "source": "/ikojn-dresses", "destination": "/api/index.js" },
    { "source": "/nalani-dresses-collection", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
